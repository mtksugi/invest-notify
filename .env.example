# OpenAI互換API
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
# stageごとの上書き（任意。指定があれば OPENAI_MODEL より優先）
# 例: stage1は安く、stage2は高精度に
# OPENAI_MODEL_STAGE1=gpt-5-mini
# OPENAI_MODEL_STAGE2=gpt-5.2
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=180
# OPENAI_MAX_RETRIES=2

# RSS取得（SECなど）で必要になる場合がある User-Agent の連絡先
# 例: you@example.com
INVEST_NOTIFY_UA_CONTACT=

# 注視ティッカー（任意。カンマ区切り）
# 例: AAPL,MSFT,7203.T
INVEST_NOTIFY_WATCH_TICKERS=

# 注視ティッカーの別枠（追加枠）上限（任意。デフォルト: 注視ティッカーがあれば3）
INVEST_NOTIFY_WATCH_MAX=3

# 発見レーンの銘柄横断クールダウン（日, 任意。デフォルト6, 0で無効）
# 同じ銘柄をカテゴリをまたいで N 日は再通知しない（注視「別枠」bucket=watch は除外）。
# 「織り込み済みの巨大企業が何度も鳴る」状態を抑え、被覆の薄い銘柄に枠を空ける。
# INVEST_NOTIFY_TICKER_COOLDOWN_DAYS=6

# 送信直前の株価ゲート。デフォルトは有効。off/0/false/disabled を設定すると無効化。
# 60日履歴のバックテストで、通知直前の5営業日リターンが+10%以上(既に噴いた) や
# -10%未満+ネガ通知(崩れた後の追従) のケースは後続リターンが悪化する傾向が強いため、
# send/email/run 時に Yahoo Finance から直近リターンを取得し、降格/除外を行う。
# INVEST_NOTIFY_PRICE_GATE=off

# AWS SES SMTP
# 例: email-smtp.ap-northeast-1.amazonaws.com
SES_SMTP_HOST=
SES_SMTP_PORT=587
SES_SMTP_USER=
SES_SMTP_PASS=

# 送信元（SES Verified domain配下のFrom）
MAIL_FROM=invest-notify@inmylife65.net

# 送信先（複数の場合はカンマ区切り）
MAIL_TO=

# ----- Multibagger Radar (v0.3) -----
# FMP (Financial Modeling Prep) - Starter プラン以上
# https://site.financialmodelingprep.com/
FMP_API_KEY=
# 任意。デフォルト値は radar/fmp.py 参照
# FMP_TIMEOUT_SECONDS=30
# FMP_REQUEST_SLEEP=0.05
# FMP_MAX_RETRIES=3

